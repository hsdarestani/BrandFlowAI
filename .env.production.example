# Copy to .env.production on the server. Never commit the real values.
APP_ENV=staging
DEMO_MODE=false
ALLOW_MOCK_CONNECTORS=false
ALLOW_UNSAFE_DEV_DEFAULTS=false
REQUIRE_MIGRATIONS=true
RUN_MIGRATIONS=true

POSTGRES_PASSWORD=replace-with-a-long-random-value
DATABASE_URL=postgresql+psycopg://smarbiz:replace-with-a-long-random-value@postgres:5432/smarbiz
REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_MINUTES=10080
JWT_ISSUER=smarbiz-api
CONNECTOR_SECRET_KEY=replace-with-at-least-32-random-characters
BOOTSTRAP_SUPERADMIN_EMAIL=
AUTH_RATE_LIMIT_PER_MINUTE=12

AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

CORS_ORIGINS=https://smarbiz.sbs,https://www.smarbiz.sbs
NEXT_PUBLIC_API_URL=/api
ACME_EMAIL=admin@smarbiz.sbs

TELEGRAM_BOT_TOKEN=
BALE_BOT_TOKEN=
BALE_BASE_URL=https://tapi.bale.ai/bot{token}/{method}
BALE_SAFIR_BASE_URL=
BALE_SAFIR_API_ACCESS_KEY=
BALE_SAFIR_BOT_ID=

S3_ENDPOINT=
S3_BUCKET=smarbiz-assets
